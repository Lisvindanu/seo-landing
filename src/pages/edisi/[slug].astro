---
import Base from '../../layouts/Base.astro';
import editions from '../../data/editions.json';

const showcases = import.meta.glob('../../editions/*.astro', { eager: true });

export function getStaticPaths() {
  const list = [...editions].sort((a, b) => a.no - b.no);
  return list.map((ed, i) => ({
    params: { slug: ed.slug },
    props: {
      ed,
      prev: i > 0 ? list[i - 1] : null,
      next: i < list.length - 1 ? list[i + 1] : null,
    },
  }));
}

const { ed, prev, next } = Astro.props;
const Showcase = showcases[`../../editions/${ed.slug}.astro`].default;

const title = `Edisi ${ed.slug} — ${ed.title} — Bidang Abstrak`;
const description = ed.subtitle;
---

<Base title={title} description={description} path={`/edisi/${ed.slug}/`}>
  <Showcase />
  <nav class="edisi-nav" aria-label="Navigasi antar edisi">
    {prev ? (
      <a class="edisi-nav__link edisi-nav__link--prev" href={`/edisi/${prev.slug}/`} rel="prev">
        <span class="edisi-nav__dir">← Edisi {prev.slug}</span>
        <span class="edisi-nav__title">{prev.title}</span>
      </a>
    ) : <span aria-hidden="true"></span>}

    <a class="edisi-nav__link edisi-nav__link--index" href="/arsip/">Daftar isi</a>

    {next ? (
      <a class="edisi-nav__link edisi-nav__link--next" href={`/edisi/${next.slug}/`} rel="next">
        <span class="edisi-nav__dir">Edisi {next.slug} →</span>
        <span class="edisi-nav__title">{next.title}</span>
      </a>
    ) : <span aria-hidden="true"></span>}
  </nav>
</Base>

<style>
  .edisi-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-3, 1rem);
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--space-6, 3rem) var(--space-4, 1.5rem) var(--space-8, 5rem);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
  .edisi-nav__link {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    color: var(--ink);
    text-decoration: none;
    padding: 0.75rem 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius, 10px);
    transition: border-color 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .edisi-nav__link--next { text-align: right; }
  .edisi-nav__link--index {
    justify-self: center;
    text-align: center;
    color: var(--ink-soft);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .edisi-nav__link:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .edisi-nav__dir { color: var(--ink-soft); }
  .edisi-nav__title { color: var(--ink); font-weight: 600; }
  @media (max-width: 640px) {
    .edisi-nav { grid-template-columns: 1fr; }
    .edisi-nav__link--next { text-align: left; }
  }
</style>
